{
  "name": "squasher",
  "displayName": "Squasher",
  "description": "Adds squash commit functionality to the VS Code Source Control Graph",
  "version": "0.0.0-placeholder",
  "publisher": "timheuer",
  "author": {
    "name": "Tim Heuer",
    "url": "https://github.com/timheuer"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/timheuer/squasher.git"
  },
  "bugs": {
    "url": "https://github.com/timheuer/squasher/issues"
  },
  "qna": "https://github.com/timheuer/squasher/issues",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "enabledApiProposals": [
    "contribSourceControlHistoryItemMenu"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "squasher.squashCommits",
        "title": "Squash Commits up to HEAD...",
        "category": "Squasher"
      },
      {
        "command": "squasher.squashCommitsFromPalette",
        "title": "Squash Commits...",
        "category": "Squasher"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "squasher.squashCommits",
          "when": "false"
        },
        {
          "command": "squasher.squashCommitsFromPalette",
          "when": "true"
        }
      ],
      "scm/historyItem/context": [
        {
          "command": "squasher.squashCommits",
          "when": "scmProvider == git",
          "group": "1_modification@50"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
